// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  EXPIRED
}

enum AppointmentType {
  IN_PERSON
  VIRTUAL
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  username          String?   @unique
  passwordHash      String
  name              String
  role              Role      @default(PATIENT)
  avatar            String?
  specialization    String?   // For doctors
  contact           String?
  gender            String?
  dob               DateTime?
  bloodGroup        String?
  address           String?
  isAvailable       Boolean   @default(true)
  preferredLanguage String?   @default("en")
  vitalBp           String?
  vitalWeight       String?
  vitalGlucose      String?
  vitalTemperature  String?
  otp               String?   // For forgot password
  otpExpiry         DateTime? // Expiration time for OTP
  lastSessionId     String?   // For single-session management
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  doctorAppointments  Appointment[] @relation("DoctorAppointments")
  patientAppointments Appointment[] @relation("PatientAppointments")
  patientReports      Report[]
  doctorReports       Report[]      @relation("DoctorReports")
  notifications       Notification[]
  pushSubscriptions   PushSubscription[]
  doctorSchedules     DoctorSchedule[] @relation("DoctorSchedules")
  blockedSlots        BlockedSlot[]    @relation("BlockedSlots")
  reminders           Reminder[]

  @@index([role])
}

model Appointment {
  id          String            @id @default(uuid())
  doctorId    String
  patientId   String
  date        DateTime
  time        String?           // "09:00" format
  status      AppointmentStatus @default(PENDING)
  type        AppointmentType   @default(VIRTUAL)
  meetingLink String?           // For virtual meetings
  timezoneOffset Int           @default(-330) // Default to IST offset (-330 mins) if not provided
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  doctor  User @relation("DoctorAppointments", fields: [doctorId], references: [id])
  patient User @relation("PatientAppointments", fields: [patientId], references: [id])

  @@index([doctorId])
  @@index([patientId])
  @@index([date])
}

model Report {
  id              String   @id @default(uuid())
  patientId       String
  diagnosis       String
  confidenceScore Float?
  precautions     Json     // Stored as JSON array or object
  chatTranscript  Json     // Stored as JSON object for conversation history
  summary         String?
  symptoms        Json?    // Array of symptoms
  medications     Json?    // Array of medication objects or strings for reminders
  history         Json?    // Patient Q&A
  vitals          Json?    // {bp, weight, temperature}
  reportType      String   @default("AI")  // "AI" | "CONSULTATION" | "UPLOADED"
  fileUrl         String?  // URL for uploaded report files
  fileName        String?  // Original filename for uploaded reports
  createdAt       DateTime @default(now())

  // Relations
  patient User @relation(fields: [patientId], references: [id], onDelete: Cascade)
  reminders Reminder[]

  @@index([patientId])
  doctor  User? @relation("DoctorReports", fields: [doctorId], references: [id]) 
  doctorId String?
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String?  @default("INFO")
  metadata  Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DoctorSchedule {
  id        String  @id @default(uuid())
  doctorId  String
  dayIndex  Int     // 0=Sun, 1=Mon, ..., 6=Sat
  startTime String  // "09:00"
  endTime   String  // "18:00"
  isActive  Boolean @default(true)

  doctor User @relation("DoctorSchedules", fields: [doctorId], references: [id], onDelete: Cascade)
}

model BlockedSlot {
  id        String @id @default(uuid())
  doctorId  String
  date      String // "2026-03-17"
  startTime String // "10:00"
  endTime   String // "12:00"
  reason    String // "Surgery", "Personal Leave"

  doctor User @relation("BlockedSlots", fields: [doctorId], references: [id], onDelete: Cascade)
}

enum MedicationUnit {
  TABLET
  CAPSULE
  ML
  MG
  DROPS
  INJECTION
}

model Reminder {
  id             String         @id @default(uuid())
  userId         String
  reportId       String?
  medicationName String
  dosage         String?
  unit           MedicationUnit @default(TABLET)
  remindTimes    String[]       // Array of HH:mm values (e.g., ["08:00", "20:00"])
  startDate      DateTime       @default(now())
  endDate        DateTime?
  isActive       Boolean        @default(true)
  timezoneOffset Int            @default(-330) // Default to IST offset (-330 mins) if not provided
  createdAt      DateTime       @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  report Report? @relation(fields: [reportId], references: [id])

  @@index([userId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
