# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# PostgreSQL Database Connection URL (Prisma connection string)
# Replace 'your_password' with your actual local/cloud Postgres database password
DATABASE_URL="mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/medecho?retryWrites=true&w=majority"

# JWT Secret Key (Used to sign secure session tokens. Change this to a random secret in production)
JWT_SECRET="medecho_secret_key_change_this_in_production"

# URL of the Python ML Service (Default: http://localhost:8000)
ML_SERVICE_URL="http://localhost:8000"

# Server Port (Default: 5000)
PORT=5000

# Frontend URL (Used in password reset email buttons. Default: http://localhost:5173 or http://localhost:3000)
FRONTEND_URL="http://localhost:5173"

# Gemini API Key (Used by backend services, e.g. ocrRefiner or fallback scripts)
GEMINI_API_KEY="your_gemini_api_key_here"

# D-ID API Key (Required by server to authorize video/avatar streams to D-ID)
# Formatted as: Basic [base64EncodedCredentials]
DID_API_KEY="your_did_api_key_here"

# SMTP Email Settings (Brevo / Sendinblue or Gmail SMTP credentials for sending OTPs)
SMTP_USER="your-email@example.com"
SMTP_PASS="your-smtp-app-password"

# Web Push Notification VAPID Keys (Run custom vapid key generator to create new keys)
VAPID_PUBLIC_KEY="your_vapid_public_key_here"
VAPID_PRIVATE_KEY="your_vapid_private_key_here"
VAPID_EMAIL="mailto:your_email@example.com"
